{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist/electron",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["electron/**/*.ts", "server/**/*.ts", "shared/**/*.ts"],
  "exclude": ["**/*.test.ts"]
}
